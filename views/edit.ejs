<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Edit your chat</title>

<style>

body{
    font-family: Arial, Helvetica, sans-serif;
    background:#f2f4f7;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.edit-box{
    background:white;
    padding:30px;
    width:350px;
    border-radius:12px;
    box-shadow:0 6px 18px rgba(0,0,0,0.1);
}

h3{
    margin-top:0;
    text-align:center;
    color:#333;
}

.info{
    font-size:14px;
    margin-bottom:15px;
    color:#555;
}

textarea{
    width:100%;
    padding:10px;
    border-radius:8px;
    border:1px solid #ccc;
    margin-top:10px;
    margin-bottom:15px;
    resize:none;
}

button{
    width:100%;
    padding:10px;
    background:#ff9800;
    color:white;
    border:none;
    border-radius:8px;
    font-size:15px;
    cursor:pointer;
}

button:hover{
    background:#e68900;
}

</style>
</head>

<body>

<div class="edit-box">

<h3>Edit your chat</h3>

<p class="info">
This chat was sent from <b><%= chat.from %></b> to <b><%= chat.to %></b>
</p>

<form method="post" action="/chats/<%= chat._id %>?_method=put">

<textarea name="msg" rows="5"><%= chat.msg %></textarea>

<button>Edit Chat</button>

</form>

</div>

</body>
</html>